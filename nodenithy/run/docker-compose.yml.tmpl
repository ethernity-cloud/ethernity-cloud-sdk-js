# Publish-time compose: used by ecld-publish to compute the MRENCLAVE
# (SCONE_HASH=1) and extract the enclave certificate LOCALLY. It intentionally
# does NOT mount /dev/sgx_enclave so it runs on a developer machine WITHOUT SGX
# (SCONE_HASH is a build measurement; enclaves reach SGX via LAS over TCP). When
# no local SGX is present, cert extraction falls back to the remote
# publickey.ethernity.cloud service. The on-node runtime uses
# docker-compose-final.yml, which targets real SGX hardware.
version: '3.2'
services:
  las:
    container_name: las
    privileged: true
    image: localhost:5000/etny-las
    entrypoint: "/las_entrypoint.sh"
    command: "/usr/local/bin/las"
    restart: on-failure
    ports:
      - target: 18766
        published: 18766
        protocol: tcp
        mode: host

  etny-securelock:
    container_name: etny-securelock
    privileged: true
    image: localhost:5000/etny-securelock
    entrypoint: ""
    command: [ "/usr/local/bin/node", "/etny-securelock/securelock.js" ]
    environment:
      - SCONE_CAS_ADDR=scone-cas.cf
      - SCONE_LAS_ADDR=las
      - SCONE_CONFIG_ID=__ENCLAVE_NAME_SECURELOCK__/application
      - SCONE_HEAP=1024M
      # Must match the --stack the securelock binary was signed with (build.mjs),
      # otherwise SCONE recomputes MRENCLAVE at load and re-signs as debug.
      - SCONE_STACK=4M
      - SCONE_LOG=DEBUG
      - SCONE_ALLOW_DLOPEN=1
      - SCONE_EXTENSIONS_PATH=/lib/libbinary-fs.so
    restart: on-failure:5
    depends_on:
      - las

  etny-trustedzone:
    container_name: etny-trustedzone
    privileged: true
    image: localhost:5000/etny-trustedzone
    entrypoint: ""
    command: [ "/usr/local/bin/node", "/etny-trustedzone/trustedzone.js" ]
    environment:
      - SCONE_CAS_ADDR=scone-cas.cf
      - SCONE_LAS_ADDR=las
      - SCONE_CONFIG_ID=__ENCLAVE_NAME_TRUSTEDZONE__/application
      - SCONE_HEAP=256M
      - SCONE_LOG=DEBUG
      - SCONE_ALLOW_DLOPEN=1
      - SCONE_EXTENSIONS_PATH=/lib/libbinary-fs.so
    restart: on-failure
    depends_on:
      - las

  etny-validator:
    container_name: etny-validator
    privileged: true
    image: localhost:5000/etny-validator
    entrypoint: ""
    command: [ "/usr/local/bin/node", "/etny-validator/validator.js" ]
    environment:
      - SCONE_CAS_ADDR=scone-cas.cf
      - SCONE_LAS_ADDR=las
      - SCONE_CONFIG_ID=ecld-nodenithy/application
      - SCONE_HEAP=256M
      - SCONE_LOG=DEBUG
      - SCONE_ALLOW_DLOPEN=1
      - SCONE_EXTENSIONS_PATH=/lib/libbinary-fs.so
    restart: on-failure:5
    depends_on:
      - las
